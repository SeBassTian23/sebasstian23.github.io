---
layout: home
pagination:
  data: collections.tagList
  size: 1
  alias: tag
  addAllPagesToCollections: true
excludeFromSitemap: true
eleventyComputed:
  permalink: "| tags/#{ filters.slugify(tag) }/"
  title: "| Tag #{\"|\"} #{tag}"
  description: "| All Posts with the Tag \"#{tag}\""
---
include /shared/block-hero
include /shared/block-post
block append content
  
  - var headerImage = filters.imageResizedURL( image || filters.titleImgFromAlbum(album) || collections[ tag ].toReversed()[0].data.image || filters.titleImgFromAlbum(collections[ tag ].toReversed()[0].data.album), "webp", 1500) || {url: null}
  +hero-1({h2: tag})(class="mb-4", style=`background-image: linear-gradient(135deg,rgba(var(--bs-secondary-rgb), ${headerImage.url? "0.85" : "1.0"}) 50%, rgba(var(--bs-primary-rgb), ${headerImage.url? "0.85" : "1.0"}) 100%)${headerImage.url? ", url(" + headerImage.url + ");" : ";"} background-position: center; background-size: cover;`)

  section.container
    .row.mb-1.px-2
      .col
        nav(style=`--bs-breadcrumb-divider: '▸';` aria-label="breadcrumb")
          ol.breadcrumb
            li.breadcrumb-item: a(href="/posts/") Posts
            li.breadcrumb-item: a(href="/tags/") Tags
            li.breadcrumb-item.text-uppercase.active(aria-current="page") #{tag}
    .row 
      .col
        .row.row-cols-1.row-cols-sm-2.row-cols-md-3.g-3
          for post in collections[ tag ].toReversed()
            +post-card(post)(class="mb-4")